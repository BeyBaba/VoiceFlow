# VoiceFlow - Environment Variables
# Copy this file to .env and fill in the values

# NextAuth
AUTH_SECRET=          # openssl rand -base64 32
AUTH_GOOGLE_ID=       # Google OAuth Client ID
AUTH_GOOGLE_SECRET=   # Google OAuth Client Secret

# Groq AI (Whisper transcription)
GROQ_API_KEY=         # https://console.groq.com

# Base URL
NEXT_PUBLIC_BASE_URL=https://voice-flow-six.vercel.app

# LemonSqueezy Payment
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=
LEMONSQUEEZY_VARIANT_PRO_YEARLY=
LEMONSQUEEZY_VARIANT_LIFETIME=

# Database (PostgreSQL - Neon/Supabase/PlanetScale)
DATABASE_URL=postgresql://user:password@host:5432/voiceflow?sslmode=require

# GitHub (for private release downloads)
GITHUB_TOKEN=
